{
    "name": "nachopitt/migrations",
    "description": "Import database tables and write them to Laravel migration files.",
    "type": "library",
    "homepage": "https://github.com/nachopitt/migrations",
    "keywords": ["database","sql","mysql","laravel","migration"],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "laravel/framework": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "phpmyadmin/sql-parser": "^5.7"
    },
    "autoload": {
        "psr-4": {
            "Nachopitt\\Migrations\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nachopitt\\Migrations\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nachopitt\\Migrations\\ConsoleSupportServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6|^10.0|^11.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "shipmonk/composer-dependency-analyser": "^1.8",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=always --testdox",
        "analyse-deps": "vendor/bin/composer-dependency-analyser",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "format": "vendor/bin/php-cs-fixer fix"
    }
}
